{
  "name": "data-capture",
  "version": "1.0.0",
  "description": "Data Capture with client and server",
  "scripts": {
    "predev": "kill-port 3000 3001 5173",
    "dev": "concurrently -k \"npm run server\" \"npm run client\" \"npm run rental-app\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "rental-app": "set PORT=3001 && node app.js",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "dependencies": {
    "concurrently": "^8.2.0"
  },
  "devDependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "kill-port": "^2.0.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.2",
    "path": "^0.12.7"
  }
}
